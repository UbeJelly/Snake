; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Snake"
run/main_scene="uid://cybg413dhj0v0"
run/disable_stdout=true
run/disable_stderr=true
config/disable_project_settings_override=true
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Global="*uid://bmg0207pn48lr"

[display]

window/size/viewport_width=750
window/size/viewport_height=800
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/dpi/allow_hidpi=false
mouse_cursor/custom_image="uid://dyhgbnmys2xi7"
mouse_cursor/custom_image_hotspot=Vector2(10, 10)
mouse_cursor/tooltip_position_offset=Vector2(32, 32)

[editor]

naming/scene_name_casing=1
naming/script_name_casing=1

